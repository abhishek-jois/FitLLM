# FitLLM Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# CLI flags override these values when provided.
# All sizes are in gigabytes (GB) unless noted.

# ── Model ─────────────────────────────────────────────────────────────────────
# HuggingFace model ID or local path to the large (verifier) model.
FITLLM_MODEL=Qwen/Qwen2.5-32B-Instruct

# Small draft model for speculative decoding. Must be from the same model
# family as FITLLM_MODEL to share the same tokenizer.
# Leave blank to use greedy decoding only.
#   Qwen2.5 verifier  → Qwen/Qwen2.5-1.5B-Instruct
#   Llama 3.x verifier → meta-llama/Llama-3.2-1B-Instruct
FITLLM_DRAFT_MODEL=

# Directory where per-layer shard files are saved / loaded.
FITLLM_SHARD_DIR=./shards

# ── VRAM Budget ───────────────────────────────────────────────────────────────
# Hard cap on FitLLM's OWN GPU memory usage. Enforced live against
# torch.cuda.memory_reserved() — not a startup snapshot. Set this to the
# amount of VRAM you want FitLLM to use, regardless of what else is on the GPU.
#
# Common values:
#   4.0   → RTX 3060 (12 GB card, 4 GB reserved for FitLLM)  — proven with Qwen2.5-32B
#   8.0   → GTX 1080 Ti / RTX 3070 level
#   24.0  → RTX 3090 / 4090
FITLLM_VRAM_LIMIT_GB=4.0

# VRAM headroom reserved for CUDA kernel overhead, activations, and
# miscellaneous allocations. Do not set below 0.5.
FITLLM_GPU_SAFETY_MARGIN_GB=0.75

# ── CPU RAM Budget ─────────────────────────────────────────────────────────────
# Total CPU RAM budget across model loading and the weight cache combined.
FITLLM_CPU_RAM_LIMIT_GB=16.0

# How much of that budget to dedicate to the shard weight cache.
# Set to 0 to let FitLLM auto-size based on available RAM minus safety margin.
# Higher values = more layers cached in RAM = faster backward pass.
FITLLM_WEIGHT_CACHE_GB=13.0

# CPU RAM always kept free for the OS and other processes.
FITLLM_CPU_SAFETY_MARGIN_GB=3.0

# ── Quantization ──────────────────────────────────────────────────────────────
# How to compress model weights when sharding.
#   4bit  → NF4 double-quantization (recommended): ~0.24 GB/layer for 32B
#   8bit  → LLM.int8(): ~0.48 GB/layer for 32B
#   fp16  → Half-precision: ~0.96 GB/layer for 32B
FITLLM_COMPRESSION=4bit

# ── Inference ─────────────────────────────────────────────────────────────────
FITLLM_MAX_NEW_TOKENS=512
FITLLM_TEMPERATURE=0.7

# Number of tokens the draft model proposes per speculative step.
# Higher k → more tokens accepted per step if the draft is good,
# but more wasted compute if it's wrong. 4 is a safe default.
FITLLM_SPECULATIVE_K=4

# ── Fine-tuning (LoRA) ────────────────────────────────────────────────────────
# LoRA rank. Higher = more expressive adapter, larger file, slower.
# 16 is the standard for 32B+ models.
FITLLM_LORA_RANK=16

# LoRA alpha scaling factor. Typically 2× rank.
FITLLM_LORA_ALPHA=32

# Which attention projections to adapt. Standard recipe: q_proj + v_proj only.
# Adding k_proj and o_proj gives marginal benefit at 25-50% extra compute cost.
FITLLM_LORA_TARGETS=q_proj,v_proj

# Gradient accumulation steps. Effective batch size = grad_accum × 1 (batch_size=1).
# Higher values stabilize training but delay optimizer steps.
FITLLM_GRAD_ACCUM=16

# Base learning rate. 1e-4 is conservative and safe for 32B models.
FITLLM_LR=1e-4

# Total training steps. 9380 ≈ 10 epochs of dolly-15k with grad_accum=16.
FITLLM_MAX_STEPS=9380

# Maximum input + output token length per example.
FITLLM_MAX_SEQ_LEN=512

# Where to save training checkpoints.
FITLLM_CHECKPOINT_DIR=./checkpoints

# LR schedule: linear warmup for this many steps, then cosine decay to zero.
FITLLM_WARMUP_STEPS=50

# Gradient clipping threshold. Prevents loss spikes on large models.
# Set to 0 to disable.
FITLLM_MAX_GRAD_NORM=1.0

# ── Shard-Stationary Training ─────────────────────────────────────────────────
# Inverts the training loop: each shard is loaded ONCE per optimizer step and
# ALL grad_accum mini-batches are processed through it before eviction.
# Reduces RAM→GPU transfers from (grad_accum × 2 × layers) to (2 × layers).
# Recommended: always leave this on (1).
FITLLM_SHARD_STATIONARY=1

# ── I/O Pipeline ──────────────────────────────────────────────────────────────
# Number of shard batches to prefetch ahead of the current compute batch.
# Higher = more I/O threads = less GPU stall waiting for next shard.
# Diminishing returns above 4; uses more CPU RAM for pinned buffers.
FITLLM_PREFETCH_DEPTH=4

# ── Shard Integrity ───────────────────────────────────────────────────────────
# Verify SHA-256 checksums on every shard load. Safe to disable during
# training to avoid CPU overhead (64 layers × 2 passes = 128 SHA256/step).
# Always leave on (1) for inference or initial verification.
FITLLM_VERIFY_CHECKSUMS=0

# ── Experiment Tracking ───────────────────────────────────────────────────────
# Set to 1 and pass --log-wandb at the CLI to enable WandB logging.
# Requires: pip install wandb && wandb login
FITLLM_LOG_WANDB=0

# ── PyTorch / CUDA Tweaks ─────────────────────────────────────────────────────
# Disable torch.compile — not needed for layer-by-layer sharded training and
# causes multi-hour hangs on first step due to Inductor kernel compilation.
TORCH_COMPILE_DISABLE=1
